# Guest Manager — Environment Configuration
# ==========================================
# Copy this file to `.env` and fill in your values.
# Variables prefixed with `VITE_` are exposed to the browser.
# Variables without the prefix are server-only (never sent to the client).

# ---------------------------------------------------------------------------
# PUBLIC (Client-Side) — VITE_ prefix
# ---------------------------------------------------------------------------

# Application display name shown in the UI and browser tab
VITE_APP_NAME=Guest Manager

# Base URL for backend API calls (leave empty to use localStorage-only mode)
VITE_API_BASE_URL=

# Enable/disable authentication screen (true | false)

# ---------------------------------------------------------------------------
# SERVER-ONLY (Not exposed to the browser)
# ---------------------------------------------------------------------------

# Example: secret key for signing server-side tokens or webhooks
# API_SECRET_KEY=your-secret-key-here

# Example: database connection string
# DATABASE_URL=postgresql://localhost:5432/guest_manager
